# একটি কাস্টম নেটওয়ার্ক তৈরি করুন
docker network create my_app_network

# আপনার পোস্টগ্রেস কন্টেইনারটি যদি অলরেডি রান থাকে, তবে আগেরটা স্টপ করে নেটওয়ার্কসহ রান করুন:
docker rm -f my_postgres_db

docker run -d \
  --name my_postgres_db \
  --network my_app_network \
  -p 5432:5432 \
  -e POSTGRES_USER=sakin \
  -e POSTGRES_PASSWORD=sakin123 \
  -e POSTGRES_DB=logs \
  postgres:alpine